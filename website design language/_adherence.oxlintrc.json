{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/navigation/**",
              "ds-loader.js",
              "image-slot.js",
              "ui_kits/portfolio-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Work Sans|Red Hat Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Work Sans, Red Hat Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|onClick|variant|size|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, href, onClick, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|blue)$/]",
        "message": "<Button> variant must be one of 'solid' | 'outline' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LedgerRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|title|meta|year|pattern|src|slotId|href|onClick|last|key|ref|className|style|children)$/]",
        "message": "<LedgerRow> doesn't accept that prop. Declared props: index, title, meta, year, pattern, src, slotId, href, onClick, last."
      },
      {
        "selector": "JSXOpeningElement[name.name='LedgerRow'] > JSXAttribute[name.name='pattern'] > Literal[value!=/^(?:grid|lines|rings|dots|solid)$/]",
        "message": "<LedgerRow> pattern must be one of 'grid' | 'lines' | 'rings' | 'dots' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHero'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|accent|lede|notes|key|ref|className|style|children)$/]",
        "message": "<PageHero> doesn't accept that prop. Declared props: title, accent, lede, notes."
      },
      {
        "selector": "JSXOpeningElement[name.name='PostRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|title|readTime|href|onClick|last|key|ref|className|style|children)$/]",
        "message": "<PostRow> doesn't accept that prop. Declared props: date, title, readTime, href, onClick, last."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:left|right|strong|key|ref|className|style|children)$/]",
        "message": "<SectionStrip> doesn't accept that prop. Declared props: left, right, strong."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:left|right|onRight|key|ref|className|style|children)$/]",
        "message": "<SiteFooter> doesn't accept that prop. Declared props: left, right, onRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onNav|name|links|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: active, onNav, name, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='Specimen'] > JSXAttribute > JSXIdentifier[name!=/^(?:pattern|height|width|label|index|src|slotId|style|key|ref|className|style|children)$/]",
        "message": "<Specimen> doesn't accept that prop. Declared props: pattern, height, width, label, index, src, slotId, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Specimen'] > JSXAttribute[name.name='pattern'] > Literal[value!=/^(?:grid|lines|rings|dots|solid)$/]",
        "message": "<Specimen> pattern must be one of 'grid' | 'lines' | 'rings' | 'dots' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|href|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, active, onClick, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticker'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|tone|duration|key|ref|className|style|children)$/]",
        "message": "<Ticker> doesn't accept that prop. Declared props: text, tone, duration."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticker'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|blue)$/]",
        "message": "<Ticker> tone must be one of 'ink' | 'blue'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
